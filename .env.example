# Local-only placeholders for development.
# Do not commit real secrets, staging values, or production values.

# API runtime
PORT=4000

# Local PostgreSQL development container
POSTGRES_USER=dcaosv1_dev
POSTGRES_PASSWORD=dcaosv1_dev_password_change_me
POSTGRES_DB=dcaosv1_dev
POSTGRES_PORT=5434
DATABASE_URL=postgresql://dcaosv1_dev:dcaosv1_dev_password_change_me@127.0.0.1:5434/dcaosv1_dev?schema=public

# Docker Compose staging uses service DNS inside dca_net.
# Keep real staging values only in the server-side .env file.
# DATABASE_URL=postgresql://<user>:<password>@dcaosv1-postgres:5432/<database>?schema=public

# Controlled MVP auth policy
AUTH_SESSION_TTL_MINUTES=480
AUTH_LOGIN_MAX_FAILED_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_MINUTES=15

# Web build/runtime
VITE_API_BASE_URL=/api/v1

# Local smoke only. Set real local-only values in the shell, not in committed files.
# AUTH_SEED_TEST_EMAIL=
# AUTH_SEED_TEST_PASSWORD=
# AUTH_SEED_TESTER_EMAIL=
# AUTH_SEED_TESTER_PASSWORD=
# MVP_SMOKE_API_BASE_URL=http://127.0.0.1:4000/api/v1

# Future staging smoke only. Use staging-only credentials in the shell.
# The smoke script currently allows only https://system.digitalcubeagency.net/api/v1 for controlled staging mode.
# MVP_SMOKE_API_BASE_URL=https://system.digitalcubeagency.net/api/v1
