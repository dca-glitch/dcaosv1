# Local-only placeholders for development.
# Do not commit real secrets, staging values, or production values.

# API runtime
PORT=4000

# Local PostgreSQL development container
POSTGRES_USER=dcaosv1_dev
POSTGRES_PASSWORD=dcaosv1_dev_password_change_me
POSTGRES_DB=dcaosv1_dev
POSTGRES_PORT=5434
DATABASE_URL=postgresql://dcaosv1_dev:dcaosv1_dev_password_change_me@127.0.0.1:5434/dcaosv1_dev?schema=public

# Docker Compose staging uses service DNS inside dca_net.
# Keep real staging values only in the server-side .env file.
# DATABASE_URL=postgresql://<user>:<password>@dcaosv1-postgres:5432/<database>?schema=public

# Controlled MVP auth policy
AUTH_SESSION_TTL_MINUTES=480
AUTH_LOGIN_MAX_FAILED_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_MINUTES=15
# TURNSTILE_ENABLED=false
# TURNSTILE_SECRET_KEY=server-side-only
# VITE_TURNSTILE_SITE_KEY=

# Web build/runtime
VITE_API_BASE_URL=/api/v1

# Local smoke only. Set real local-only values in the shell, not in committed files.
# AUTH_SEED_TEST_EMAIL=
# AUTH_SEED_TEST_PASSWORD=
# AUTH_SEED_TESTER_EMAIL=
# AUTH_SEED_TESTER_PASSWORD=
# MVP_SMOKE_API_BASE_URL=http://127.0.0.1:4000/api/v1

# Optional local private object storage for admin-only document/asset uploads.
# Leave unset to keep private storage disabled locally and return guarded
# R2_STORAGE_NOT_CONFIGURED responses from private upload endpoints.
# Required for private storage writes:
# R2_ACCOUNT_ID=example-account-id
# R2_ACCESS_KEY_ID=example-access-key-id
# R2_SECRET_ACCESS_KEY=example-secret-access-key
# R2_BUCKET_NAME=example-private-bucket
# Optional overrides used by the current storage helpers:
# R2_ENDPOINT=https://example-account-id.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://assets.example.test

# Future AI text provider planning only. Local deterministic execution remains
# active unless AI_TEXT_GATEWAY is explicitly changed in a local/server env file.
# Do not commit real provider keys or model IDs.
# AI_TEXT_GATEWAY=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_TEXT_PRIMARY_MODEL=
# OPENROUTER_TEXT_SECONDARY_MODEL=
# OPENROUTER_TEXT_REVIEWER_MODEL=
# OPENROUTER_TEXT_LONG_CONTEXT_MODEL=

# Future staging smoke only (G4). Use staging-only credentials in the shell.
# smoke:mvp:staging allows only https://staging.digitalcubeagency.net/api/v1 (G1 approved staging host).
# MVP_SMOKE_API_BASE_URL=https://staging.digitalcubeagency.net/api/v1

# Client/domain operating model (local dev optional)
# TENANT_MODULE_ENFORCEMENT=off
# TENANT_MODULE_ENFORCEMENT=dry_run
# TENANT_MODULE_ENFORCEMENT=enforce
# Restart API after changing. See docs/security/TENANT_MODULE_ENFORCEMENT.md
# Publication target credential encryption (Architecture Block 4). Generate with:
# [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
# Restart API after setting. See docs/security/CREDENTIAL_ENCRYPTION_FOUNDATION.md
# CREDENTIAL_ENCRYPTION_MASTER_KEY=
# WORDPRESS_PUBLISH_ENABLED=false
# Set true only after CREDENTIAL_ENCRYPTION_MASTER_KEY is configured. Restart API. See docs/security/WORDPRESS_PUBLISH_LOCAL_GATE.md
