{
  "name": "@dca-os-v1/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "check": "node ../../scripts/check-package.mjs api && npm run check:auth-skeleton && tsc --noEmit",
