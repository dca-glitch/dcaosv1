{
  "name": "dca-os-v1",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable SaaS operating system foundation for Digital Cube Agency.",
  "packageManager": "npm",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "node scripts/run-sequential.mjs \"node scripts/check-workspace.mjs\" \"npm run --workspaces --if-present check\"",
    "build": "npm run --workspaces --if-present build",
    "validate": "node scripts/run-sequential.mjs \"npm run -w @dca-os-v1/data prisma:generate\" \"npm run check\" \"npm run build\"",
    "test": "node scripts/run-sequential.mjs \"npm run test:unit\" \"npm run test:integration\"",
    "test:unit": "node scripts/run-sequential.mjs \"npm run -w @dca-os-v1/api test:unit\" \"npm run -w @dca-os-v1/web test:unit\"",
    "test:integration": "npm run -w @dca-os-v1/api test:integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "dev:web": "npm run -w @dca-os-v1/web dev",
    "dev:api": "npm run -w @dca-os-v1/api dev",
    "restore:local-admin": "tsx scripts/restore-local-admin.mjs",
    "bootstrap:staging-admin": "node scripts/bootstrap-staging-admin.mjs",
    "smoke:local": "powershell -ExecutionPolicy Bypass -File scripts/smoke-local.ps1",
    "smoke:browser": "powershell -ExecutionPolicy Bypass -File scripts/smoke-browser.ps1",
    "smoke:client-domain:browser": "node scripts/smoke-client-domain-browser-local.mjs",
