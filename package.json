{
  "name": "dca-os-v1",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable SaaS operating system foundation for Digital Cube Agency.",
  "packageManager": "npm",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "node scripts/check-workspace.mjs && npm run --workspaces --if-present check",
    "build": "npm run --workspaces --if-present build",
    "validate": "npm run -w @dca-os-v1/data prisma:generate && npm run check && npm run build",
    "dev:web": "npm run -w @dca-os-v1/web dev",
    "dev:api": "npm run -w @dca-os-v1/api dev",
    "restore:local-admin": "tsx scripts/restore-local-admin.mjs",
    "smoke:local": "powershell -ExecutionPolicy Bypass -File scripts/smoke-local.ps1",
    "smoke:browser": "powershell -ExecutionPolicy Bypass -File scripts/smoke-browser.ps1",
    "smoke:client-domain:browser": "node scripts/smoke-client-domain-browser-local.mjs",
    "smoke:credential-encryption:local": "node scripts/smoke-credential-encryption-local.mjs",
    "smoke:wordpress-publish:local": "node scripts/smoke-wordpress-publish-local.mjs",
    "smoke:tenant-module:local": "node --import tsx scripts/smoke-tenant-module-local.mjs",
    "smoke:legacy-wordpress-sunset:local": "node scripts/smoke-legacy-wordpress-sunset-local.mjs",
    "smoke:ai-delivery-reviews": "node scripts/smoke-ai-delivery-reviews-local.mjs",
    "smoke:ai-market-intelligence": "node scripts/smoke-ai-market-intelligence-local.mjs",
    "smoke:mvp:local": "node scripts/smoke-mvp-local.mjs",
    "smoke:mvp:staging": "node scripts/smoke-mvp-local.mjs --staging",
    "smoke:client-portal:local": "node scripts/smoke-client-portal-local.mjs",
    "smoke:client-portal:browser": "node scripts/smoke-client-portal-browser-local.mjs",
    "smoke:client-portal:signed-out:browser": "node scripts/smoke-client-portal-signed-out-browser-local.mjs",
    "smoke:client-portal:edge-cases:browser": "node scripts/smoke-client-portal-edge-cases-browser-local.mjs",
    "smoke:client-portal:sparse-delivery:browser": "node scripts/smoke-client-portal-sparse-delivery-browser-local.mjs",
    "smoke:client-portal:populated-delivery:browser": "node scripts/smoke-client-portal-populated-delivery-browser-local.mjs",
    "smoke:client-portal:access-revoke:browser": "node scripts/smoke-client-portal-access-revoke-browser-local.mjs",
    "smoke:client-portal:empty-archive:browser": "node scripts/smoke-client-portal-empty-archive-browser-local.mjs",
    "smoke:client-hub:catalog-inquiry:browser": "node scripts/smoke-client-hub-catalog-inquiry-browser-local.mjs",
    "smoke:client-hub:publication-log:browser": "node scripts/smoke-client-hub-publication-log-browser-local.mjs",
    "smoke:client-portal:project-filter:browser": "node scripts/smoke-client-portal-project-filter-browser-local.mjs",
    "smoke:client-access:local": "node scripts/smoke-client-access-local.mjs",
    "smoke:client-access:browser": "node scripts/smoke-client-access-browser-local.mjs",
    "smoke:dashboard:audit-feed:browser": "node scripts/smoke-dashboard-audit-feed-browser-local.mjs",
    "smoke:settings-team:browser": "node scripts/smoke-settings-team-browser-local.mjs",
    "smoke:content-plan-review:browser": "node scripts/smoke-content-plan-review-browser-local.mjs",
    "smoke:monthly-report:local": "node scripts/smoke-monthly-report-local.mjs",
    "smoke:monthly-report:browser": "node scripts/smoke-browser-monthly-report-admin-ui.mjs",
    "smoke:monthly-report:pdf": "node scripts/smoke-monthly-report-pdf-local.mjs",
    "smoke:monthly-report:mi-context": "node scripts/smoke-monthly-report-mi-context-local.mjs",
    "smoke:monthly-report:metrics": "node scripts/smoke-monthly-report-metrics-local.mjs",
    "smoke:client-portal-monthly-report:browser": "node scripts/smoke-client-portal-monthly-report-browser-local.mjs",
    "smoke:google-drive-export": "node scripts/smoke-google-drive-export-local.mjs",
    "smoke:pre-staging:local": "powershell -ExecutionPolicy Bypass -File scripts/smoke-pre-staging-local.ps1"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
