generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  DELETED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum RoleStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  DELETED
}

enum ModuleStatus {
  PLANNED
  ACTIVE
  DEPRECATED
  RETIRED
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  DATE
}

enum AuditActorType {
  USER
  SYSTEM
  AUTOMATION
  API
}

model Tenant {
  id            String            @id @default(uuid())
  name          String
  slug          String            @unique
  status        TenantStatus
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  memberships   TenantMembership[]
  roles         Role[]
  tenantModules TenantModule[]
  tenantSettings TenantSetting[]
  auditLogs     AuditLog[]        @relation("TenantAuditLogs")
}

model User {
  id          String            @id @default(uuid())
  email       String            @unique
  name        String?
  status      UserStatus
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?
  memberships TenantMembership[]
  auditLogs   AuditLog[]        @relation("UserAuditLogs")
}

model TenantMembership {
  id              String            @id @default(uuid())
  tenantId        String
  userId          String
  status          MembershipStatus
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  membershipRoles MembershipRole[]

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([status])
}

model Role {
  id              String            @id @default(uuid())
  tenantId        String
  key             String
  name            String
  description     String?
  status          RoleStatus
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  membershipRoles MembershipRole[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

model Permission {
  id              String            @id @default(uuid())
  key             String            @unique
  moduleKey       String?
  description     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  rolePermissions RolePermission[]

  @@index([moduleKey])
}

model RolePermission {
  id           String       @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime     @default(now())
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model MembershipRole {
  id                String           @id @default(uuid())
  tenantMembershipId String
  roleId             String
  createdAt          DateTime         @default(now())
  tenantMembership   TenantMembership @relation(fields: [tenantMembershipId], references: [id], onDelete: Cascade)
  role               Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantMembershipId, roleId])
  @@index([tenantMembershipId])
  @@index([roleId])
}

model ModuleDefinition {
  id            String         @id @default(uuid())
  key           String         @unique
  name          String
  description   String?
  status        ModuleStatus
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenantModules TenantModule[]

  @@index([status])
}

model TenantModule {
  id                 String           @id @default(uuid())
  tenantId           String
  moduleDefinitionId String
  status             ModuleStatus
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  moduleDefinition   ModuleDefinition  @relation(fields: [moduleDefinitionId], references: [id], onDelete: Restrict)

  @@unique([tenantId, moduleDefinitionId])
  @@index([tenantId])
  @@index([moduleDefinitionId])
  @@index([status])
}

model TenantSetting {
  id          String            @id @default(uuid())
  tenantId    String
  key         String
  moduleKey   String?
  valueType   SettingValueType
  value       Json
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([moduleKey])
}

model AuditLog {
  id          String         @id @default(uuid())
  tenantId    String?
  actorType   AuditActorType
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime       @default(now())
  tenant      Tenant?        @relation("TenantAuditLogs", fields: [tenantId], references: [id], onDelete: SetNull)
  actorUser   User?          @relation("UserAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([actorUserId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}
