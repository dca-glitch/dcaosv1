generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  DELETED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum RoleStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  DELETED
}

enum ModuleStatus {
  PLANNED
  ACTIVE
  DEPRECATED
  RETIRED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskRecurringType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOIDED
  UNCOLLECTIBLE
}

enum RecurringInvoiceInterval {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum BillPaymentForm {
  CASH
  REVOLUT_BANK
  WISE_BANK
  REVOLUT_CARD
  WISE_CARD
  OTHER
}

enum FinanceEventType {
  REVENUE
  COST
}

enum FinanceEventSource {
  INVOICE
  BILL
  DELIVERY
  MANUAL
  SYSTEM
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  DATE
}

enum AuditActorType {
  USER
  SYSTEM
  AUTOMATION
  API
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
}

enum EmailTemplateKey {
  CLIENT_INVITE
  PASSWORD_RESET
  AI_DELIVERY_BRIEF_REQUEST
  AI_DELIVERY_REVIEW_REQUEST
  AI_DELIVERY_APPROVED
  INVOICE_ISSUED
}

enum ClientKind {
  AGENCY_CLIENT
  OWN_DOMAIN
}

enum ClientMigrationStatus {
  ACTIVE
  PLANNED_LICENSEE_TENANT
  MIGRATED
}

enum PublicationConnectorType {
  WORDPRESS
}

enum PublicationLogStatus {
  PREPARED
  PROVIDER_DISABLED
  PUBLISHED
  FAILED
}

enum AnalyticsConnectionStatus {
  MANUAL
  CONFIGURED
  LIVE_DEFERRED
}

enum AiDeliveryBriefStatus {
  DRAFT
  CLIENT_INPUT_REQUESTED
  CLIENT_SUBMITTED
  REVISION_REQUESTED
  CLIENT_REVISED
  ADMIN_APPROVED
}

enum BriefType {
  MONTHLY
  ADDITIONAL
}

enum BriefStatus {
  DRAFT
  AWAITING_CLIENT
  SUBMITTED
}

enum WorkflowBriefSource {
  CLIENT_PORTAL
  ADMIN_PANEL
}

enum WorkflowBriefCreatedByRole {
  CLIENT
  ADMIN
}

enum WorkflowBriefStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  READY_FOR_AI
  AI_RUNNING
  AI_RESULTS_READY
  APPROVED_FOR_PRODUCTION
  ARCHIVED
}

enum AiBriefRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum AiReportStatus {
  DRAFT
  READY
  APPROVED
  REJECTED
  ARCHIVED
}

enum ProductionPlanStatus {
  DRAFT
  SENT_TO_CLIENT
  APPROVED
  CHANGES_REQUESTED
  ARCHIVED
}

enum BriefApprovalDecisionType {
  APPROVE
  REJECT
  REQUEST_CHANGES
  SUBMIT
  ARCHIVE
}

enum BriefApprovalTargetType {
  BRIEF
  MI_REPORT
  SEO_REPORT
  PRODUCTION_PLAN
}

enum BriefApprovalActorRole {
  CLIENT
  ADMIN
}

model Tenant {
  id                   String                @id @default(uuid())
  name                 String
  slug                 String                @unique
  status               TenantStatus
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  memberships          TenantMembership[]
  roles                Role[]
  clients              Client[]
  projects             Project[]
  tasks                Task[]
  invoices             Invoice[]
  recurringInvoices    RecurringInvoice[]
  recurringInvoiceRuns RecurringInvoiceRun[]
  vendors              Vendor[]
  bills                Bill[]
  tenantModules        TenantModule[]
  tenantSettings       TenantSetting[]
  auditLogs            AuditLog[]            @relation("TenantAuditLogs")
  companyProfile       CompanyProfile?
  invoiceItems         InvoiceItem[]
  invoicePayments      InvoicePayment[]
  creditNotes          CreditNote[]
  projectDocuments     ProjectDocument[]
  aiDeliveryProjects   AiDeliveryProject[]
  aiDeliveryBriefs     AiDeliveryBrief[]
  aiDeliveryContentPlans AiDeliveryContentPlan[]
  aiDeliveryContentPlanItems AiDeliveryContentPlanItem[]
  aiDeliveryContentDrafts AiDeliveryContentDraft[]
  aiDeliveryArticleImages AiDeliveryArticleImage[]
  aiDeliveryDeliverables AiDeliveryDeliverable[]
  aiDeliveryDeliverableReviews AiDeliveryDeliverableReview[]
  aiDeliveryWorkflowRuns AiDeliveryWorkflowRun[]
  aiDeliveryResearchRequests AiDeliveryResearchRequest[]
  aiDeliveryResearchSources AiDeliveryResearchSource[]
  aiDeliveryResearchSummaries AiDeliveryResearchSummary[]
  aiDeliveryMonthlyMetricSnapshots AiDeliveryMonthlyMetricSnapshot[]
  marketIntelligenceProjects MarketIntelligenceProject[]
  marketIntelligenceSources MarketIntelligenceSource[]
  marketIntelligenceResearchRuns MarketIntelligenceResearchRun[]
  marketIntelligenceInsights MarketIntelligenceInsight[]
  marketIntelligenceHandoffs MarketIntelligenceHandoff[]
  clientUserAccesses   ClientUserAccess[]
  emailLogs            EmailLog[]            @relation("TenantEmailLogs")
  aiDeliveryMonthlyReports AiDeliveryMonthlyReport[]
  aiKnowledgeItems     AiKnowledgeItem[]
  aiContextSnapshots   AiContextSnapshot[]
  financeEvents        FinanceEvent[]
  financeMonthlySnapshots FinanceMonthlySnapshot[]
  revenueAttributions  RevenueAttribution[]
  publicationTargets   PublicationTarget[]
  publicationTargetCredentials PublicationTargetCredential[]
  clientAnalyticsProfiles ClientAnalyticsProfile[]
  publicationLogs      PublicationLog[]
  clientCatalogProducts ClientCatalogProduct[]
  clientCatalogInquiries ClientCatalogInquiry[]
  workflowBriefs       Brief[]
  aiBriefRuns          AiBriefRun[]
  aiMiReports          AiMiReport[]
  aiSeoReports         AiSeoReport[]
  briefApprovals       BriefApproval[]
  productionPlans      ProductionPlan[]
}

model User {
  id                       String             @id @default(uuid())
  email                    String             @unique
  name                     String?
  status                   UserStatus
  passwordHash             String?
  passwordChangedAt        DateTime?
  forcePasswordChange      Boolean            @default(false)
  failedLoginCount         Int                @default(0)
  lockedUntil              DateTime?
  lastLoginAt              DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  deletedAt                DateTime?
  memberships              TenantMembership[]
  sessions                 Session[]
  auditLogs                AuditLog[]         @relation("UserAuditLogs")
  uploadedProjectDocuments ProjectDocument[]  @relation("ProjectDocumentUploadedBy")
  clientUserAccesses       ClientUserAccess[]
  aiDeliveryMonthlyMetricSnapshotsImportedBy AiDeliveryMonthlyMetricSnapshot[] @relation("AiDeliveryMonthlyMetricSnapshotImportedByUser")
  aiDeliveryMonthlyMetricSnapshotsApprovedBy  AiDeliveryMonthlyMetricSnapshot[] @relation("AiDeliveryMonthlyMetricSnapshotApprovedByUser")
  publicationTargetCredentialsUpdated PublicationTargetCredential[] @relation("PublicationTargetCredentialUpdatedByUser")
  aiKnowledgeItemsCreated   AiKnowledgeItem[] @relation("AiKnowledgeItemCreatedByUser")
  aiKnowledgeItemsReviewed  AiKnowledgeItem[] @relation("AiKnowledgeItemReviewedByUser")
  aiKnowledgeItemsApproved  AiKnowledgeItem[] @relation("AiKnowledgeItemApprovedByUser")
  aiKnowledgeItemVersionsCreated AiKnowledgeItemVersion[] @relation("AiKnowledgeItemVersionCreatedByUser")
  aiContextSnapshotsCreated AiContextSnapshot[] @relation("AiContextSnapshotCreatedByUser")
  deliverableClientEdits    ClientEdit[]        @relation("DeliverableClientEdits")
  workflowBriefsCreated     Brief[]             @relation("WorkflowBriefCreatedBy")
  workflowBriefsReviewed    Brief[]             @relation("WorkflowBriefAdminReviewedBy")
  aiBriefRunsTriggered      AiBriefRun[]        @relation("AiBriefRunTriggeredBy")
  briefApprovals            BriefApproval[]     @relation("BriefApprovalActor")
}

model Session {
  id                       String            @id @default(uuid())
  userId                   String
  sessionTokenHash         String            @unique
  activeTenantMembershipId String?
  createdAt                DateTime          @default(now())
  expiresAt                DateTime
  revokedAt                DateTime?
  lastSeenAt               DateTime?
  ipAddress                String?
  userAgent                String?
  user                     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeTenantMembership   TenantMembership? @relation("SessionActiveTenantMembership", fields: [activeTenantMembershipId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([activeTenantMembershipId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([createdAt])
}

model TenantMembership {
  id              String           @id @default(uuid())
  tenantId        String
  userId          String
  status          MembershipStatus
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  membershipRoles MembershipRole[]
  activeSessions  Session[]        @relation("SessionActiveTenantMembership")

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([status])
}

model Role {
  id              String           @id @default(uuid())
  tenantId        String
  key             String
  name            String
  description     String?
  status          RoleStatus
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  membershipRoles MembershipRole[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique
  moduleKey       String?
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@index([moduleKey])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model MembershipRole {
  id                 String           @id @default(uuid())
  tenantMembershipId String
  roleId             String
  createdAt          DateTime         @default(now())
  tenantMembership   TenantMembership @relation(fields: [tenantMembershipId], references: [id], onDelete: Cascade)
  role               Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantMembershipId, roleId])
  @@index([tenantMembershipId])
  @@index([roleId])
}

model ModuleDefinition {
  id            String         @id @default(uuid())
  key           String         @unique
  name          String
  description   String?
  status        ModuleStatus
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenantModules TenantModule[]

  @@index([status])
}

model CompanyProfile {
  id                  String   @id @default(uuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                String
  legalName           String?
  email               String?
  phone               String?
  website             String?
  taxId               String?
  country             String?
  registrationNumber  String?
  billingAddress      String?
  paymentInstructions String?
  logoUrl             String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  currency            String   @default("USD")
  invoiceTemplateKey  String   @default("classic")
  invoicePrefix       String?
  creditNotePrefix    String?

  @@unique([tenantId])
  @@index([isActive])
  @@index([tenantId])
}

model Client {
  id                String             @id @default(uuid())
  tenantId          String
  name              String
  email             String?
  phone             String?
  website           String?
  billingDetails    String?
  contactPerson     String?
  taxId             String?
  country           String?
  notes             String?
  clientKind        ClientKind         @default(AGENCY_CLIENT)
  legalEntityName   String?
  accountGroupName  String?
  migrationStatus   ClientMigrationStatus @default(ACTIVE)
  isArchived        Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects          Project[]
  invoices          Invoice[]
  recurringInvoices RecurringInvoice[]
  aiDeliveryProjects AiDeliveryProject[]
  userAccesses       ClientUserAccess[]
  aiDeliveryMonthlyReports AiDeliveryMonthlyReport[]
  publicationTargets PublicationTarget[]
  analyticsProfile  ClientAnalyticsProfile?
  marketIntelligenceProjects MarketIntelligenceProject[]
  publicationLogs   PublicationLog[]
  catalogProducts   ClientCatalogProduct[]
  catalogInquiries  ClientCatalogInquiry[]
  aiKnowledgeItems  AiKnowledgeItem[]
  financeEvents     FinanceEvent[]
  revenueAttributions RevenueAttribution[]
  workflowBriefs      Brief[]

  @@index([tenantId])
  @@index([tenantId, isArchived])
  @@index([tenantId, clientKind])
  @@index([tenantId, migrationStatus])
}

model PublicationTarget {
  id               String                   @id @default(uuid())
  tenantId         String
  clientId         String
  label            String
  connectorType    PublicationConnectorType @default(WORDPRESS)
  siteUrl          String
  siteSlug         String?
  wordPressComSite Boolean                  @default(false)
  isDefault        Boolean                  @default(false)
  isArchived       Boolean                  @default(false)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  tenant       Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client       Client                      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  credentials  PublicationTargetCredential?
  publicationLogs PublicationLog[]

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, clientId, isArchived])
  @@index([tenantId, clientId, isDefault])
}

model PublicationTargetCredential {
  id                  String   @id @default(uuid())
  tenantId            String
  publicationTargetId String   @unique
  ciphertext          String
  iv                  String
  authTag             String
  updatedByUserId     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  publicationTarget PublicationTarget @relation(fields: [publicationTargetId], references: [id], onDelete: Cascade)
  updatedByUser     User?             @relation("PublicationTargetCredentialUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, publicationTargetId])
}

model ClientAnalyticsProfile {
  id                String                    @id @default(uuid())
  tenantId          String
  clientId          String                    @unique
  gscSiteUrl        String?
  ga4PropertyId     String?
  defaultSourceType MonthlyMetricSourceType   @default(MANUAL)
  connectionStatus  AnalyticsConnectionStatus @default(MANUAL)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, clientId])
}

model PublicationLog {
  id                  String               @id @default(uuid())
  tenantId            String
  clientId            String
  publicationTargetId String?
  aiDeliveryProjectId String?
  deliverableId       String?
  action              String
  status              PublicationLogStatus
  siteUrlHost         String?
  externalPostId      String?
  actorUserId         String?
  note                String?
  createdAt           DateTime             @default(now())

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client            Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  publicationTarget PublicationTarget? @relation(fields: [publicationTargetId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, deliverableId])
  @@index([tenantId, createdAt])
}

enum ClientCatalogInquiryStatus {
  NEW
  ACKNOWLEDGED
  CLOSED
}

model ClientCatalogProduct {
  id                String   @id @default(uuid())
  tenantId          String
  clientId          String
  name              String
  description       String?
  sku               String?
  priceLabel        String?
  imageUrl          String?
  sortOrder         Int      @default(0)
  isVisibleInPortal Boolean  @default(true)
  isArchived        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client    Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  inquiries ClientCatalogInquiry[]

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, clientId, isArchived])
  @@index([tenantId, clientId, isVisibleInPortal])
}

model ClientCatalogInquiry {
  id                String                     @id @default(uuid())
  tenantId          String
  clientId          String
  productId         String?
  contactName       String
  contactEmail      String
  contactPhone      String?
  message           String
  status            ClientCatalogInquiryStatus @default(NEW)
  submittedByUserId String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  tenant  Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client  Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product ClientCatalogProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, clientId, status])
  @@index([tenantId, productId])
}

model ClientUserAccess {
  id         String   @id @default(uuid())
  tenantId   String
  clientId   String
  userId     String
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, clientId, userId])
  @@index([tenantId])
  @@index([clientId])
  @@index([userId])
  @@index([isArchived])
  @@index([tenantId, clientId])
  @@index([tenantId, userId])
  @@index([tenantId, isArchived])
}

model Project {
  id                String             @id @default(uuid())
  tenantId          String
  clientId          String?
  name              String
  description       String?
  startDate         DateTime?
  dueDate           DateTime?
  status            String             @default("Active")
  isArchived        Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client            Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  tasks             Task[]
  invoices          Invoice[]
  recurringInvoices RecurringInvoice[]
  documents         ProjectDocument[]
  aiDeliveryProjects AiDeliveryProject[]
  financeEvents     FinanceEvent[]
  revenueAttributions RevenueAttribution[]

  @@index([tenantId])
  @@index([tenantId, isArchived])
  @@index([tenantId, clientId])
}

model AiDeliveryProject {
  id                       String           @id @default(uuid())
  tenantId                 String
  clientId                 String
  projectId                String?
  sourceBriefId            String?
  name                     String
  targetMonth              DateTime
  plannedContentScopeNotes String?
  isArchived               Boolean          @default(false)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sourceBrief Brief? @relation("SourceBriefProjects", fields: [sourceBriefId], references: [id], onDelete: SetNull)
  brief AiDeliveryBrief?
  contentPlans AiDeliveryContentPlan[]
  contentDrafts AiDeliveryContentDraft[]
  articleImages AiDeliveryArticleImage[]
  deliverables AiDeliveryDeliverable[]
  deliverableReviews AiDeliveryDeliverableReview[]
  workflowRuns AiDeliveryWorkflowRun[]
  researchRequests AiDeliveryResearchRequest[]
  researchSources AiDeliveryResearchSource[]
  researchSummaries AiDeliveryResearchSummary[]
  monthlyReports AiDeliveryMonthlyReport[]
  aiDeliveryMonthlyMetricSnapshots AiDeliveryMonthlyMetricSnapshot[]
  marketIntelligenceHandoffs MarketIntelligenceHandoff[]
  aiKnowledgeItems         AiKnowledgeItem[]
  aiContextSnapshots       AiContextSnapshot[]
  productionPlans          ProductionPlan[]

  @@index([tenantId])
  @@index([tenantId, isArchived])
  @@index([tenantId, clientId])
  @@index([tenantId, projectId])
  @@index([tenantId, targetMonth])
  @@index([tenantId, sourceBriefId])
}

model AiDeliveryBrief {
  id                    String                @id @default(uuid())
  tenantId              String
  aiDeliveryProjectId   String                @unique
  status                AiDeliveryBriefStatus @default(DRAFT)
  clientPriorities      String?
  productsServicesFocus String?
  targetAudience        String?
  marketsCompetitors    String?
  notes                 String?
  revisionCount         Int                   @default(0)
  submittedAt           DateTime?
  revisionRequestedAt   DateTime?
  revisedAt             DateTime?
  approvedAt            DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiDeliveryProject AiDeliveryProject @relation(fields: [aiDeliveryProjectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, aiDeliveryProjectId])
}

// Legacy client monthly/additional brief submissions (table "Brief").
// Distinct from workflow Brief (table "WorkflowBrief") and AiDeliveryBrief (project-scoped).
model ClientMonthlyBrief {
  id              String      @id @default(cuid())
  companyId       String
  clientId        String
  briefNumber     Int         @default(0)
  targetGroup     String?
  hubCount        Int         @default(0)
  geoSeoCount     Int         @default(0)
  lifestyleCount  Int         @default(0)
  otherCount      Int         @default(0)
  type            BriefType
  month           Int?
  year            Int?
  title           String
  content         String      @db.Text
  status          BriefStatus @default(DRAFT)
  submittedById   String?
  submittedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([clientId, type, month, year], name: "unique_monthly_brief")
  @@index([companyId])
  @@index([clientId])
  @@map("Brief")
}

// Workflow initiation brief: content/SEO/MI entry point before production.
// Maps to table "WorkflowBrief". Not the legacy monthly Brief table or AiDeliveryBrief.
model Brief {
  id                      String                   @id @default(uuid())
  tenantId                String
  clientId                String
  source                  WorkflowBriefSource
  createdByUserId         String
  createdByRole           WorkflowBriefCreatedByRole
  title                   String
  goal                    String?
  businessContext         String?                  @db.Text
  targetAudience          String?
  offerContext            String?
  locationContext         String?
  notes                   String?                  @db.Text
  structuredInputJson     Json?
  status                  WorkflowBriefStatus      @default(DRAFT)
  adminReviewedAt         DateTime?
  adminReviewedByUserId   String?
  aiRequestedAt           DateTime?
  approvedForProductionAt DateTime?
  archivedAt              DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client              Client              @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdByUser       User                @relation("WorkflowBriefCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  adminReviewedByUser User?               @relation("WorkflowBriefAdminReviewedBy", fields: [adminReviewedByUserId], references: [id], onDelete: SetNull)
  aiBriefRuns         AiBriefRun[]
  miReports           AiMiReport[]
  seoReports          AiSeoReport[]
  approvals           BriefApproval[]
  productionPlans     ProductionPlan[]
  sourceProjects      AiDeliveryProject[] @relation("SourceBriefProjects")
  deliverables        AiDeliveryDeliverable[]

  @@index([tenantId])
