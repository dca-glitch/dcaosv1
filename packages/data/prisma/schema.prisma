  @@unique([tenantId, source, sourceEntityId])
  @@index([tenantId, type, timestamp])
  @@index([tenantId, clientId])
  @@index([tenantId, projectId])
  @@index([tenantId, timestamp])
}

model FinanceMonthlySnapshot {
  id                String   @id @default(uuid())
  tenantId          String
  month             String
  totalRevenueCents Int      @default(0)
  totalCostCents    Int      @default(0)
  profitCents       Int      @default(0)
  marginPercent     Float    @default(0)
