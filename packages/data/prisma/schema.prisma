  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedByUser User?   @relation("ProjectDocumentUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, projectId])
  @@index([tenantId, isArchived])
  @@index([tenantId, documentDate])
}

model MarketIntelligenceProject {
  id                  String                         @id @default(uuid())
  tenantId            String
  clientId            String?
  title               String
  description         String?
  keywords            String?
  competitors         String?
  niche               String?
  productServiceFocus String?
  targetClientName    String?
  targetMonth         String?
  status              String                         @default("ACTIVE")
  isArchived          Boolean                        @default(false)
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  tenant        Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client        Client?                        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  sources       MarketIntelligenceSource[]
  researchRuns  MarketIntelligenceResearchRun[]
  insights      MarketIntelligenceInsight[]
  handoffs      MarketIntelligenceHandoff[]

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, status])
  @@index([tenantId, isArchived])
}

model MarketIntelligenceSource {
  id            String                  @id @default(uuid())
  tenantId      String
  projectId     String
  title         String
  sourceType    String?
  sourceUrl     String?
  sourceNotes   String?
  isArchived    Boolean                 @default(false)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project       MarketIntelligenceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, projectId])
  @@index([tenantId, isArchived])
}

model MarketIntelligenceResearchRun {
  id            String                  @id @default(uuid())
  tenantId      String
  projectId     String
  status        String                  @default("PENDING")
  resultSummary String?
  executionLog  String?
  executedAt    DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project       MarketIntelligenceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, projectId])
  @@index([tenantId, status])
}

model MarketIntelligenceInsight {
  id            String                  @id @default(uuid())
  tenantId      String
  projectId     String
  title         String
  summary       String?
  resultData    Json?
  status        String                  @default("DRAFT")
  reviewerNotes String?
  isArchived    Boolean                 @default(false)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project       MarketIntelligenceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  handoffs      MarketIntelligenceHandoff[]

  @@index([tenantId])
  @@index([tenantId, projectId])
  @@index([tenantId, status])
  @@index([tenantId, isArchived])
}

model MarketIntelligenceHandoff {
  id                  String   @id @default(uuid())
  tenantId            String
  projectId           String
  insightId           String
  clientId            String?
  title               String
  marketSummary       String?
  competitorSummary   String?
  audienceSignals     Json?
  opportunities       Json?
  risks               Json?
  recommendedActions  Json?
  sourceNote          String?
  targetClientName    String?
  targetMonth         String?
  // DRAFT → READY → APPLIED; ARCHIVED for soft-removal
  handoffStatus         String   @default("DRAFT")
  isArchived            Boolean  @default(false)
  // Optional link to an AI Delivery project for internal context
  aiDeliveryProjectId   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project           MarketIntelligenceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  insight           MarketIntelligenceInsight @relation(fields: [insightId], references: [id], onDelete: Cascade)
  aiDeliveryProject AiDeliveryProject?        @relation(fields: [aiDeliveryProjectId], references: [id], onDelete: SetNull)
  monthlyReports    AiDeliveryMonthlyReport[]

  @@index([tenantId])
  @@index([tenantId, projectId])
  @@index([tenantId, clientId])
  @@index([tenantId, insightId])
  @@index([tenantId, handoffStatus])
  @@index([tenantId, isArchived])
  @@index([tenantId, aiDeliveryProjectId])
}

enum AiKnowledgeScope {
  SYSTEM
  CLIENT
  PROJECT
  INDUSTRY
}

enum AiKnowledgeType {
  CLIENT_FACT
  BRAND_VOICE
  TARGET_AUDIENCE
  PRODUCT_SERVICE
  OFFER
  COMPETITOR
  RESEARCH_NOTE
  MARKET_INSIGHT
  SEO_KEYWORD_GROUP
  CONTENT_EXAMPLE
  IMAGE_STYLE
  REPORT_INSIGHT
  PERFORMANCE_LEARNING
  FORBIDDEN_CLAIM
  APPROVED_LINK
  PROJECT_CONTEXT
  INDUSTRY_NOTE
}

enum AiKnowledgeStatus {
  RAW
  REVIEWED
  APPROVED
  EXPIRED
  ARCHIVED
  REPLACED
}

enum AiContextSnapshotStatus {
  PREVIEW
  USED
  ARCHIVED
}

model AiKnowledgeItem {
  id                  String            @id @default(uuid())
  tenantId            String
  clientId            String?
  aiDeliveryProjectId String?
  scope               AiKnowledgeScope
  type                AiKnowledgeType
  status              AiKnowledgeStatus @default(RAW)
  title               String
  summary             String?
  body                String?
  sourceType          String?
  sourceUrl           String?
  sourceDate          DateTime?
  confidence          String?
  expiresAt           DateTime?
  evergreen           Boolean           @default(false)
  allowedForPrompt    Boolean           @default(false)
  clientVisible       Boolean           @default(false)
  version             Int               @default(1)
  replacedById        String?
  createdByUserId     String?
  reviewedByUserId    String?
  approvedByUserId    String?
  approvedAt          DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client              Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  aiDeliveryProject   AiDeliveryProject? @relation(fields: [aiDeliveryProjectId], references: [id], onDelete: SetNull)
  replacedBy          AiKnowledgeItem?  @relation("AiKnowledgeItemReplacement", fields: [replacedById], references: [id], onDelete: SetNull)
  replaces            AiKnowledgeItem[] @relation("AiKnowledgeItemReplacement")
  createdByUser       User?             @relation("AiKnowledgeItemCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  reviewedByUser      User?             @relation("AiKnowledgeItemReviewedByUser", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  approvedByUser      User?             @relation("AiKnowledgeItemApprovedByUser", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  versions            AiKnowledgeItemVersion[]

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, aiDeliveryProjectId])
  @@index([tenantId, scope, status])
  @@index([tenantId, type, status])
  @@index([tenantId, allowedForPrompt])
  @@index([tenantId, status])
}

model AiKnowledgeItemVersion {
  id               String            @id @default(uuid())
  knowledgeItemId  String
  version          Int
  title            String
  summary          String?
  body             String?
  status           AiKnowledgeStatus
  allowedForPrompt Boolean
  clientVisible    Boolean
  expiresAt        DateTime?
  changeReason     String?
  createdByUserId  String?
  createdAt        DateTime          @default(now())

  knowledgeItem    AiKnowledgeItem   @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)
  createdByUser    User?             @relation("AiKnowledgeItemVersionCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([knowledgeItemId])
  @@index([knowledgeItemId, version])
}

model AiContextSnapshot {
  id                  String                  @id @default(uuid())
  tenantId            String
  clientId            String?
  aiDeliveryProjectId String?
  workflowRunId       String?
  purpose             String
  status              AiContextSnapshotStatus @default(PREVIEW)
  contextHash         String
  contextPreview      String
  selectedSourcesJson Json
  warningsJson        Json
  missingContextJson  Json
  tokenEstimate       Int
  budgetJson          Json?
  createdByUserId     String?
  createdAt           DateTime                @default(now())

  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiDeliveryProject   AiDeliveryProject?      @relation(fields: [aiDeliveryProjectId], references: [id], onDelete: SetNull)
  workflowRun         AiDeliveryWorkflowRun?  @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  createdByUser       User?                   @relation("AiContextSnapshotCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, aiDeliveryProjectId])
  @@index([tenantId, workflowRunId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}