generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  DELETED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum RoleStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  DELETED
}

enum ModuleStatus {
  PLANNED
  ACTIVE
  DEPRECATED
  RETIRED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskRecurringType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOIDED
  UNCOLLECTIBLE
}

enum RecurringInvoiceInterval {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum BillPaymentForm {
  CASH
  REVOLUT_BANK
  WISE_BANK
  REVOLUT_CARD
  WISE_CARD
  OTHER
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  DATE
}

enum AuditActorType {
  USER
  SYSTEM
  AUTOMATION
  API
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
}

enum EmailTemplateKey {
  CLIENT_INVITE
  PASSWORD_RESET
  AI_DELIVERY_BRIEF_REQUEST
  AI_DELIVERY_REVIEW_REQUEST
  AI_DELIVERY_APPROVED
  INVOICE_ISSUED
}

enum AiDeliveryBriefStatus {
  DRAFT
  CLIENT_INPUT_REQUESTED
  CLIENT_SUBMITTED
  REVISION_REQUESTED
  CLIENT_REVISED
  ADMIN_APPROVED
}

model Tenant {
  id                   String                @id @default(uuid())
  name                 String
  slug                 String                @unique
  status               TenantStatus
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  memberships          TenantMembership[]
  roles                Role[]
  clients              Client[]
  projects             Project[]
  tasks                Task[]
  invoices             Invoice[]
  recurringInvoices    RecurringInvoice[]
  recurringInvoiceRuns RecurringInvoiceRun[]
  vendors              Vendor[]
  bills                Bill[]
  tenantModules        TenantModule[]
  tenantSettings       TenantSetting[]
  auditLogs            AuditLog[]            @relation("TenantAuditLogs")
  companyProfile       CompanyProfile?
  invoiceItems         InvoiceItem[]
  invoicePayments      InvoicePayment[]
  creditNotes          CreditNote[]
  projectDocuments     ProjectDocument[]
  aiDeliveryProjects   AiDeliveryProject[]
  aiDeliveryBriefs     AiDeliveryBrief[]
  aiDeliveryContentPlans AiDeliveryContentPlan[]
  aiDeliveryContentPlanItems AiDeliveryContentPlanItem[]
  aiDeliveryContentDrafts AiDeliveryContentDraft[]
  aiDeliveryArticleImages AiDeliveryArticleImage[]
  aiDeliveryDeliverables AiDeliveryDeliverable[]
  aiDeliveryDeliverableReviews AiDeliveryDeliverableReview[]
  aiDeliveryWorkflowRuns AiDeliveryWorkflowRun[]
  aiDeliveryResearchRequests AiDeliveryResearchRequest[]
  aiDeliveryResearchSources AiDeliveryResearchSource[]
  aiDeliveryResearchSummaries AiDeliveryResearchSummary[]
  marketIntelligenceProjects MarketIntelligenceProject[]
  marketIntelligenceSources MarketIntelligenceSource[]
  marketIntelligenceResearchRuns MarketIntelligenceResearchRun[]
  marketIntelligenceInsights MarketIntelligenceInsight[]
  clientUserAccesses   ClientUserAccess[]
  emailLogs            EmailLog[]            @relation("TenantEmailLogs")
  aiDeliveryMonthlyReports AiDeliveryMonthlyReport[]
}

model User {
  id                       String             @id @default(uuid())
  email                    String             @unique
  name                     String?
  status                   UserStatus
  passwordHash             String?
  passwordChangedAt        DateTime?
  forcePasswordChange      Boolean            @default(false)
  failedLoginCount         Int                @default(0)
  lockedUntil              DateTime?
  lastLoginAt              DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  deletedAt                DateTime?
  memberships              TenantMembership[]
  sessions                 Session[]
  auditLogs                AuditLog[]         @relation("UserAuditLogs")
  uploadedProjectDocuments ProjectDocument[]  @relation("ProjectDocumentUploadedBy")
  clientUserAccesses       ClientUserAccess[]
}

model Session {
  id                       String            @id @default(uuid())
  userId                   String
  sessionTokenHash         String            @unique
  activeTenantMembershipId String?
  createdAt                DateTime          @default(now())
  expiresAt                DateTime
  revokedAt                DateTime?
  lastSeenAt               DateTime?
  ipAddress                String?
  userAgent                String?
  user                     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeTenantMembership   TenantMembership? @relation("SessionActiveTenantMembership", fields: [activeTenantMembershipId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([activeTenantMembershipId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([createdAt])
}

model TenantMembership {
  id              String           @id @default(uuid())
  tenantId        String
  userId          String
  status          MembershipStatus
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  membershipRoles MembershipRole[]
  activeSessions  Session[]        @relation("SessionActiveTenantMembership")

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([status])
}

model Role {
  id              String           @id @default(uuid())
  tenantId        String
  key             String
  name            String
  description     String?
  status          RoleStatus
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  membershipRoles MembershipRole[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique
  moduleKey       String?
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@index([moduleKey])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model MembershipRole {
  id                 String           @id @default(uuid())
  tenantMembershipId String
  roleId             String
  createdAt          DateTime         @default(now())
  tenantMembership   TenantMembership @relation(fields: [tenantMembershipId], references: [id], onDelete: Cascade)
  role               Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantMembershipId, roleId])
  @@index([tenantMembershipId])
  @@index([roleId])
}

model ModuleDefinition {
  id            String         @id @default(uuid())
  key           String         @unique
  name          String
  description   String?
  status        ModuleStatus
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenantModules TenantModule[]

  @@index([status])
}

model CompanyProfile {
  id                  String   @id @default(uuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                String
  legalName           String?
  email               String?
  phone               String?
  website             String?
  taxId               String?
  country             String?
  registrationNumber  String?
  billingAddress      String?
  paymentInstructions String?
  logoUrl             String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  currency            String   @default("USD")
  invoiceTemplateKey  String   @default("classic")
  invoicePrefix       String?
  creditNotePrefix    String?

  @@unique([tenantId])
  @@index([isActive])
  @@index([tenantId])
}

model Client {
  id                String             @id @default(uuid())
  tenantId          String
  name              String
  email             String?
  phone             String?
  website           String?
  billingDetails    String?
  contactPerson     String?
  taxId             String?
  country           String?
  notes             String?
  isArchived        Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects          Project[]
  invoices          Invoice[]
  recurringInvoices RecurringInvoice[]
  aiDeliveryProjects AiDeliveryProject[]
  userAccesses       ClientUserAccess[]
  aiDeliveryMonthlyReports AiDeliveryMonthlyReport[]

  @@index([tenantId])
  @@index([tenantId, isArchived])
}

model ClientUserAccess {
  id         String   @id @default(uuid())
  tenantId   String
  clientId   String
  userId     String
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, clientId, userId])
  @@index([tenantId])
  @@index([clientId])
  @@index([userId])
  @@index([isArchived])
  @@index([tenantId, clientId])
  @@index([tenantId, userId])
  @@index([tenantId, isArchived])
}

model Project {
  id                String             @id @default(uuid())
  tenantId          String
  clientId          String?
  name              String
  description       String?
  startDate         DateTime?
  dueDate           DateTime?
  status            String             @default("Active")
  isArchived        Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client            Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  tasks             Task[]
  invoices          Invoice[]
  recurringInvoices RecurringInvoice[]
  documents         ProjectDocument[]
  aiDeliveryProjects AiDeliveryProject[]

  @@index([tenantId])
  @@index([tenantId, isArchived])
  @@index([tenantId, clientId])
}

model AiDeliveryProject {
  id                       String           @id @default(uuid())
  tenantId                 String
  clientId                 String
  projectId                String?
  name                     String
  targetMonth              DateTime
  plannedContentScopeNotes String?
  isArchived               Boolean          @default(false)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  brief AiDeliveryBrief?
  contentPlans AiDeliveryContentPlan[]
  contentDrafts AiDeliveryContentDraft[]
  articleImages AiDeliveryArticleImage[]
  deliverables AiDeliveryDeliverable[]
  deliverableReviews AiDeliveryDeliverableReview[]
  workflowRuns AiDeliveryWorkflowRun[]
  researchRequests AiDeliveryResearchRequest[]
  researchSources AiDeliveryResearchSource[]
  researchSummaries AiDeliveryResearchSummary[]
  monthlyReports AiDeliveryMonthlyReport[]

  @@index([tenantId])
  @@index([tenantId, isArchived])
  @@index([tenantId, clientId])
  @@index([tenantId, projectId])
  @@index([tenantId, targetMonth])
}

model AiDeliveryBrief {
  id                    String                @id @default(uuid())
  tenantId              String
  aiDeliveryProjectId   String                @unique
  status                AiDeliveryBriefStatus @default(DRAFT)
  clientPriorities      String?
  productsServicesFocus String?
  targetAudience        String?
  marketsCompetitors    String?
  notes                 String?
  revisionCount         Int                   @default(0)
  submittedAt           DateTime?
  revisionRequestedAt   DateTime?
  revisedAt             DateTime?
  approvedAt            DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiDeliveryProject AiDeliveryProject @relation(fields: [aiDeliveryProjectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, aiDeliveryProjectId])
}

// Monthly Content Plan models for AI Delivery
enum AiDeliveryContentPlanStatus {
  DRAFT
  CLIENT_REVIEW_REQUESTED
  CLIENT_CHANGES_REQUESTED
  CLIENT_APPROVED
}

enum AiDeliveryContentPlanItemApprovalStatus {
  DRAFT
  CLIENT_CHANGES_REQUESTED
  CLIENT_APPROVED
}

model AiDeliveryContentPlan {
  id                   String                         @id @default(uuid())
  tenantId             String
  aiDeliveryProjectId  String
  status               AiDeliveryContentPlanStatus   @default(DRAFT)
  revisionCount        Int                            @default(0)
  reviewRequestedAt    DateTime?
  approvedAt           DateTime?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt

  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiDeliveryProject   AiDeliveryProject @relation(fields: [aiDeliveryProjectId], references: [id], onDelete: Cascade)
  items               AiDeliveryContentPlanItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@unique([tenantId, aiDeliveryProjectId])
}

model AiDeliveryContentPlanItem {
  id              String                                @id @default(uuid())
  tenantId        String
  contentPlanId   String
  title           String
  targetKeyword   String?
  contentType     String                                @default("article")
  notes           String?
  sortOrder       Int                                   @default(0)
  approvalStatus  AiDeliveryContentPlanItemApprovalStatus?
  clientComment   String?
  createdAt       DateTime                              @default(now())
  updatedAt       DateTime                              @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contentPlan   AiDeliveryContentPlan @relation(fields: [contentPlanId], references: [id], onDelete: Cascade)
  contentDrafts AiDeliveryContentDraft[]

  @@index([tenantId])
  @@index([tenantId, contentPlanId])
  @@index([tenantId, sortOrder])
}

model AiDeliveryContentDraft {
  id                  String   @id @default(uuid())
  tenantId            String
  aiDeliveryProjectId String
  contentPlanItemId   String?
  title               String
  slug                String?
  draftBody           String
  status              String   @default("DRAFT")
  notes               String?
  reviewRequestedAt   DateTime?
  approvedAt          DateTime?
  revisionCount       Int      @default(0)
  clientComment       String?
  isArchived          Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant              Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiDeliveryProject   AiDeliveryProject         @relation(fields: [aiDeliveryProjectId], references: [id], onDelete: Cascade)
  contentPlanItem     AiDeliveryContentPlanItem? @relation(fields: [contentPlanItemId], references: [id], onDelete: SetNull)
  articleImages       AiDeliveryArticleImage[]
  deliverables         AiDeliveryDeliverable[]

  @@index([tenantId])
  @@index([tenantId, aiDeliveryProjectId])
  @@index([tenantId, contentPlanItemId])
  @@index([tenantId, status])
  @@index([tenantId, isArchived])
}

model AiDeliveryArticleImage {
  id                  String   @id @default(uuid())
  tenantId            String
  aiDeliveryProjectId String
  contentDraftId      String
  title               String
  prompt              String
  styleNotes          String?
  status              String   @default("DRAFT")
  previewImageUrl     String?
  finalImageUrl       String?
  storageKey          String?
  notes               String?
  isArchived          Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiDeliveryProject   AiDeliveryProject       @relation(fields: [aiDeliveryProjectId], references: [id], onDelete: Cascade)
  contentDraft        AiDeliveryContentDraft  @relation(fields: [contentDraftId], references: [id], onDelete: Cascade)
  deliverables         AiDeliveryDeliverable[]

  @@index([tenantId])
  @@index([tenantId, aiDeliveryProjectId])
  @@index([tenantId, contentDraftId])
  @@index([tenantId, status])
  @@index([tenantId, isArchived])
}

// AI Delivery Deliverables
enum AiDeliveryDeliverableDeliveryType {
  CONTENT_PACKAGE
  ARTICLE_DRAFT
  ARTICLE_IMAGE
  CLIENT_HANDOFF
  OTHER
}

enum AiDeliveryDeliverableStatus {
  DRAFT
  READY
  DELIVERED
  REVISION_REQUESTED
  ACCEPTED
  ARCHIVED
}

model AiDeliveryDeliverable {
  id                  String   @id @default(uuid())
  tenantId            String
  aiDeliveryProjectId String
  contentDraftId      String?
  articleImageId      String?
  title               String
  description         String?
  deliveryType        AiDeliveryDeliverableDeliveryType @default(CONTENT_PACKAGE)
  status              AiDeliveryDeliverableStatus @default(DRAFT)
  exportUrl           String?
  storageKey          String?
  notes               String?
  isArchived          Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiDeliveryProject   AiDeliveryProject       @relation(fields: [aiDeliveryProjectId], references: [id], onDelete: Cascade)
  contentDraft        AiDeliveryContentDraft? @relation(fields: [contentDraftId], references: [id], onDelete: SetNull)
  articleImage        AiDeliveryArticleImage? @relation(fields: [articleImageId], references: [id], onDelete: SetNull)
  reviews             AiDeliveryDeliverableReview[]

  @@index([tenantId])
  @@index([tenantId, aiDeliveryProjectId])
  @@index([tenantId, status])
  @@index([tenantId, isArchived])
  @@index([tenantId, contentDraftId])
  @@index([tenantId, articleImageId])
}

enum AiDeliveryDeliverableReviewStatus {
  NOT_STARTED
  ADMIN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  ARCHIVED
}

model AiDeliveryDeliverableReview {
  id                  String                              @id @default(uuid())
  tenantId            String
  aiDeliveryProjectId String
  deliverableId       String
  workflowRunId       String?
  status              AiDeliveryDeliverableReviewStatus  @default(NOT_STARTED)
  reviewerName        String?
  reviewNotes         String?
  createdAt           DateTime                            @default(now())
  updatedAt           DateTime                            @updatedAt

  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiDeliveryProject   AiDeliveryProject       @relation(fields: [aiDeliveryProjectId], references: [id], onDelete: Cascade)
  deliverable         AiDeliveryDeliverable   @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  workflowRun         AiDeliveryWorkflowRun?  @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, aiDeliveryProjectId])
  @@index([tenantId, deliverableId])
  @@index([tenantId, workflowRunId])
  @@index([tenantId, status])
}

enum AiDeliveryWorkflowRunStatus {
  DRAFT
  READY
  IN_PROGRESS
  REVIEW
  COMPLETED
  FAILED
  ARCHIVED
}

model AiDeliveryWorkflowRun {
  id                  String                      @id @default(uuid())
  tenantId            String
  aiDeliveryProjectId String
  status              AiDeliveryWorkflowRunStatus @default(DRAFT)
  adminNotes          String?
  resultPlaceholder   String?
  executionLog        String?
  executionError      String?
  startedAt           DateTime?
  finishedAt          DateTime?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiDeliveryProject   AiDeliveryProject @relation(fields: [aiDeliveryProjectId], references: [id], onDelete: Cascade)
  deliverableReviews  AiDeliveryDeliverableReview[]
  researchRequests    AiDeliveryResearchRequest[]
  researchSources     AiDeliveryResearchSource[]
  researchSummaries   AiDeliveryResearchSummary[]

  @@index([tenantId])
  @@index([tenantId, aiDeliveryProjectId])
  @@index([tenantId, status])
  @@index([createdAt])
}

enum AiDeliveryResearchRequestStatus {
  DRAFT
  READY
  IN_REVIEW
  COMPLETED
  ARCHIVED
}

enum AiDeliveryResearchSourceStatus {
  PROPOSED
  APPROVED
  REJECTED
  ARCHIVED
}

enum AiDeliveryResearchSourceType {
  WEBSITE
  DOCUMENT
  OTHER
}

model AiDeliveryResearchRequest {
  id                  String                         @id @default(uuid())
  tenantId            String
  aiDeliveryProjectId String
  workflowRunId       String?
  title               String
  description         String?
  requestType         String?
  status              AiDeliveryResearchRequestStatus @default(DRAFT)
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  tenant              Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiDeliveryProject   AiDeliveryProject      @relation(fields: [aiDeliveryProjectId], references: [id], onDelete: Cascade)
  workflowRun         AiDeliveryWorkflowRun? @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  sources             AiDeliveryResearchSource[]

  @@index([tenantId])
  @@index([tenantId, aiDeliveryProjectId])
  @@index([tenantId, workflowRunId])
  @@index([tenantId, status])
}

model AiDeliveryResearchSource {
  id                  String                        @id @default(uuid())
  tenantId            String
  aiDeliveryProjectId String
  researchRequestId   String?
  workflowRunId       String?
  sourceUrl           String
  sourceTitle         String?
  sourceType          AiDeliveryResearchSourceType  @default(WEBSITE)
  status              AiDeliveryResearchSourceStatus @default(PROPOSED)
  reviewNotes         String?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  tenant              Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiDeliveryProject   AiDeliveryProject         @relation(fields: [aiDeliveryProjectId], references: [id], onDelete: Cascade)
  researchRequest     AiDeliveryResearchRequest? @relation(fields: [researchRequestId], references: [id], onDelete: SetNull)
  workflowRun         AiDeliveryWorkflowRun?    @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, aiDeliveryProjectId])
  @@index([tenantId, researchRequestId])
  @@index([tenantId, workflowRunId])
  @@index([tenantId, status])
}

enum AiDeliveryResearchSummaryStatus {
  DRAFT
  IN_REVIEW
  FINALIZED
  ARCHIVED
}

model AiDeliveryResearchSummary {
  id                     String                         @id @default(uuid())
  tenantId               String
  aiDeliveryProjectId    String
  workflowRunId          String?
  title                  String
  status                 AiDeliveryResearchSummaryStatus @default(DRAFT)
  summaryText            String
  keyFindings            String?
  audienceInsights       String?
  competitorInsights     String?
  keywordOpportunities   String?
  contentRecommendations String?
  briefRevisionNotes     String?
  sourceNotes            String?
  finalizedAt            DateTime?
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt

  tenant              Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiDeliveryProject   AiDeliveryProject      @relation(fields: [aiDeliveryProjectId], references: [id], onDelete: Cascade)
  workflowRun         AiDeliveryWorkflowRun? @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, aiDeliveryProjectId])
  @@index([tenantId, workflowRunId])
  @@index([tenantId, status])
}

// AI Delivery Monthly Report
enum AiDeliveryMonthlyReportStatus {
  DRAFT
  ADMIN_REVIEW
  FINAL
  ARCHIVED
}

model AiDeliveryMonthlyReport {
  id                  String                        @id @default(uuid())
  tenantId            String
  aiDeliveryProjectId String
  clientId            String
  status              AiDeliveryMonthlyReportStatus @default(DRAFT)
  title               String?
  adminSummaryNotes   String?
  recommendationsText String?
  exportUrl           String?
  storageKey          String?
  isArchived          Boolean                       @default(false)
  finalizedAt         DateTime?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiDeliveryProject AiDeliveryProject @relation(fields: [aiDeliveryProjectId], references: [id], onDelete: Cascade)
  client            Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)

  @@unique([tenantId, aiDeliveryProjectId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, clientId])
  @@index([tenantId, isArchived])
}

model Task {
  id            String            @id @default(uuid())
  tenantId      String
  projectId     String?
  title         String
  description   String?
  priority      TaskPriority      @default(NORMAL)
  status        TaskStatus        @default(TODO)
  dueDate       DateTime?
  recurringType TaskRecurringType @default(NONE)
  isArchived    Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project       Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, isArchived])
  @@index([tenantId, projectId])
  @@index([priority])
  @@index([status])
  @@index([recurringType])
}

model Invoice {
  id                  String            @id @default(uuid())
  tenantId            String
  clientId            String
  projectId           String?
  recurringInvoiceId  String?
  invoiceNumber       String
  status              InvoiceStatus     @default(DRAFT)
  issueDate           DateTime?
  dueDate             DateTime?
  paidAt              DateTime?
  currency            String            @default("USD")
  subtotalCents       Int               @default(0)
  taxCents            Int               @default(0)
  discountCents       Int               @default(0)
  totalCents          Int               @default(0)
  amountPaidCents     Int               @default(0)
  title               String?
  notes               String?
  paymentInstructions String?
  documentUrl         String?
  documentStorageKey  String?
  isArchived          Boolean           @default(false)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client              Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project             Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  recurringInvoice    RecurringInvoice? @relation(fields: [recurringInvoiceId], references: [id], onDelete: SetNull)
  lineItems           InvoiceLineItem[]
  voidedAt            DateTime?
  uncollectibleAt     DateTime?
  statusReason        String?
  payment             InvoicePayment?
  creditNotes         CreditNote[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, projectId])
  @@index([tenantId, status])
  @@index([tenantId, isArchived])
  @@index([tenantId, dueDate])
  @@index([recurringInvoiceId])
}

model InvoiceLineItem {
  id             String   @id @default(uuid())
  invoiceId      String
  description    String
  quantity       Int      @default(1)
  unitPriceCents Int      @default(0)
  totalCents     Int      @default(0)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model RecurringInvoice {
  id                  String                     @id @default(uuid())
  tenantId            String
  clientId            String
  projectId           String?
  title               String?
  interval            RecurringInvoiceInterval
  startDate           DateTime
  endDate             DateTime?
  nextRunDate         DateTime
  lastRunDate         DateTime?
  currency            String                     @default("USD")
  subtotalCents       Int                        @default(0)
  taxCents            Int                        @default(0)
  discountCents       Int                        @default(0)
  totalCents          Int                        @default(0)
  notes               String?
  paymentInstructions String?
  documentFolderHint  String?
  isActive            Boolean                    @default(true)
  isArchived          Boolean                    @default(false)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  tenant              Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client              Client                     @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project             Project?                   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  invoices            Invoice[]
  lineItems           RecurringInvoiceLineItem[]
  runs                RecurringInvoiceRun[]

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, projectId])
  @@index([tenantId, isActive, nextRunDate])
  @@index([tenantId, isArchived])
}

model RecurringInvoiceLineItem {
  id                 String           @id @default(uuid())
  recurringInvoiceId String
  description        String
  quantity           Int              @default(1)
  unitPriceCents     Int              @default(0)
  totalCents         Int              @default(0)
  sortOrder          Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  recurringInvoice   RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)

  @@index([recurringInvoiceId])
}

model RecurringInvoiceRun {
  id                 String           @id @default(uuid())
  tenantId           String
  recurringInvoiceId String
  scheduledFor       DateTime
  generatedInvoiceId String?
  status             String           @default("GENERATED")
  createdAt          DateTime         @default(now())
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recurringInvoice   RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)

  @@unique([recurringInvoiceId, scheduledFor])
  @@index([tenantId])
  @@index([tenantId, scheduledFor])
}

model Vendor {
  id         String   @id @default(uuid())
  tenantId   String
  name       String
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bills      Bill[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isArchived])
}

model Bill {
  id                 String          @id @default(uuid())
  tenantId           String
  vendorId           String
  amountCents        Int
  paymentForm        BillPaymentForm
  paymentDate        DateTime
  billDate           DateTime?
  dueDate            DateTime?
  referenceNumber    String?
  category           String?
  notes              String?
  documentUrl        String?
  documentStorageKey String?
  isArchived         Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor             Vendor          @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, vendorId])
  @@index([tenantId, isArchived])
  @@index([tenantId, paymentDate])
  @@index([tenantId, category])
}

model TenantModule {
  id                 String           @id @default(uuid())
  tenantId           String
  moduleDefinitionId String
  status             ModuleStatus
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  moduleDefinition   ModuleDefinition @relation(fields: [moduleDefinitionId], references: [id], onDelete: Restrict)

  @@unique([tenantId, moduleDefinitionId])
  @@index([tenantId])
  @@index([moduleDefinitionId])
  @@index([status])
}

model TenantSetting {
  id        String           @id @default(uuid())
  tenantId  String
  key       String
  moduleKey String?
  valueType SettingValueType
  value     Json
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([moduleKey])
}

model AuditLog {
  id          String         @id @default(uuid())
  tenantId    String?
  actorType   AuditActorType
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime       @default(now())
  tenant      Tenant?        @relation("TenantAuditLogs", fields: [tenantId], references: [id], onDelete: SetNull)
  actorUser   User?          @relation("UserAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([actorUserId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model EmailLog {
  id                String           @id @default(uuid())
  tenantId          String?
  recipientEmail    String
  subject           String
  templateKey       EmailTemplateKey
  status            EmailStatus
  relatedModule     String?
  relatedEntityId   String?
  providerMessageId String?
  errorMessage      String?
  createdAt         DateTime         @default(now())
  sentAt            DateTime?
  tenant            Tenant?          @relation("TenantEmailLogs", fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([recipientEmail])
  @@index([templateKey])
  @@index([status])
  @@index([relatedModule, relatedEntityId])
  @@index([createdAt])
}

enum PaymentMethod {
  CASH
  REVOLUT_BANK
  WISE_BANK
  REVOLUT_CARD
  WISE_CARD
  CARD_PROCESSOR
  OTHER
}

enum CreditNoteStatus {
  DRAFT
  ISSUED
  VOIDED
}

model InvoiceItem {
  id             String   @id @default(uuid())
  tenantId       String
  name           String
  description    String?
  unitPriceCents Int      @default(0)
  isArchived     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isArchived])
}

model InvoicePayment {
  id                  String        @id @default(uuid())
  tenantId            String
  invoiceId           String        @unique
  paymentMethod       PaymentMethod
  amountIssuedCents   Int
  amountReceivedCents Int
  paymentDate         DateTime
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, invoiceId])
  @@index([tenantId, paymentDate])
}

model CreditNote {
  id                 String           @id @default(uuid())
  tenantId           String
  invoiceId          String
  creditNoteNumber   String
  status             CreditNoteStatus @default(DRAFT)
  issueDate          DateTime?
  reason             String
  amountCents        Int              @default(0)
  currency           String           @default("USD")
  subtotalCents      Int              @default(0)
  taxCents           Int              @default(0)
  discountCents      Int              @default(0)
  totalCents         Int              @default(0)
  documentUrl        String?
  documentStorageKey String?
  isArchived         Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice   Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  lineItems CreditNoteLineItem[]

  @@unique([tenantId, creditNoteNumber])
  @@index([tenantId])
  @@index([tenantId, invoiceId])
  @@index([tenantId, status])
  @@index([tenantId, isArchived])
}

model CreditNoteLineItem {
  id             String     @id @default(uuid())
  creditNoteId   String
  description    String
  quantity       Int        @default(1)
  unitPriceCents Int        @default(0)
  totalCents     Int        @default(0)
  sortOrder      Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  creditNote     CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  @@index([creditNoteId])
}

model ProjectDocument {
  id                 String    @id @default(uuid())
  tenantId           String
  projectId          String
  fileName           String
  mimeType           String
  sizeBytes          Int
  documentType       String?
  documentDate       DateTime?
  documentUrl        String?
  documentStorageKey String
  uploadedByUserId   String?
  isArchived         Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedByUser User?   @relation("ProjectDocumentUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, projectId])
  @@index([tenantId, isArchived])
  @@index([tenantId, documentDate])
}

model MarketIntelligenceProject {
  id            String                         @id @default(uuid())
  tenantId      String
  title         String
  description   String?
  status        String                         @default("ACTIVE")
  isArchived    Boolean                        @default(false)
  createdAt     DateTime                       @default(now())
  updatedAt     DateTime                       @updatedAt

  tenant        Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sources       MarketIntelligenceSource[]
  researchRuns  MarketIntelligenceResearchRun[]
  insights      MarketIntelligenceInsight[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, isArchived])
}

model MarketIntelligenceSource {
  id            String                  @id @default(uuid())
  tenantId      String
  projectId     String
  title         String
  sourceType    String?
  sourceUrl     String?
  sourceNotes   String?
  isArchived    Boolean                 @default(false)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project       MarketIntelligenceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, projectId])
  @@index([tenantId, isArchived])
}

model MarketIntelligenceResearchRun {
  id            String                  @id @default(uuid())
  tenantId      String
  projectId     String
  status        String                  @default("PENDING")
  resultSummary String?
  executionLog  String?
  executedAt    DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project       MarketIntelligenceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, projectId])
  @@index([tenantId, status])
}

model MarketIntelligenceInsight {
  id            String                  @id @default(uuid())
  tenantId      String
  projectId     String
  title         String
  summary       String?
  resultData    Json?
  status        String                  @default("DRAFT")
  reviewerNotes String?
  isArchived    Boolean                 @default(false)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project       MarketIntelligenceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, projectId])
  @@index([tenantId, status])
  @@index([tenantId, isArchived])
}
