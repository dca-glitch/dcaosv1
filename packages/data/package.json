{
  "name": "@dca-os-v1/data",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node ../../scripts/run-sequential.mjs \"node ../../scripts/check-package.mjs data\" \"npm run prisma:validate\" \"node scripts/check-workspace-foundation.mjs\"",
    "build": "node ../../scripts/check-package.mjs data",
    "check:data-layer": "node scripts/check-data-layer.mjs",
    "prisma:validate": "node ../../scripts/run-sequential.mjs \"node scripts/validate-prisma-schema.mjs\" \"node scripts/run-prisma-validate.mjs\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "seed:db1:local": "node scripts/seed-db1.mjs",
    "workspace:mapping:dry-run": "node scripts/p1-2a-mapping-dry-run.mjs",
    "test:p1-2a": "node --test scripts/p1-2a-mapping-dry-run.test.mjs",
    "workspace:reconciliation:prepare": "node scripts/p1-3a-reconciliation-preparation.mjs",
    "test:p1-3a": "node --test scripts/p1-3a-reconciliation-preparation.test.mjs",
    "workspace:staging-rehearsal:prepare": "node scripts/p1-4a-staging-rehearsal-gate-packet.mjs",
    "test:p1-4a": "node --test scripts/p1-4a-staging-rehearsal-gate-packet.test.mjs",
    "workspace:p2-a:validate": "node scripts/p2-a-offline-foundation.mjs",
    "test:p2-a": "node --test scripts/p2-a-offline-foundation.test.mjs",
    "workspace:p2-a:owner-exporter": "node scripts/p2-a-owner-local-exporter.mjs",
    "test:p2-a:owner-exporter": "node --test scripts/p2-a-owner-local-exporter.test.mjs",
    "workspace:execution:local": "node scripts/p1-execution-local.mjs",
    "workspace:backup-rehearsal:local": "node scripts/p1-local-backup-rehearsal.mjs",
    "test:p1-execution": "node --test scripts/p1-execution-local.test.mjs scripts/p1-local-backup-rehearsal.test.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "prisma": "^5.15.0",
    "tsx": "^4.15.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
